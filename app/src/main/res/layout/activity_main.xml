<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:gravity="center_horizontal">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/header_battery"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="16dp" />

        <!-- Battery Level Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="16dp"
            android:layout_marginBottom="8dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/current_battery_label"
                android:textSize="11sp"
                android:textColor="@color/white"
                android:letterSpacing="0.15" />

            <TextView
                android:id="@+id/batteryLevelText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textSize="48sp"
                android:textStyle="bold"
                android:textColor="@color/white" />

        </LinearLayout>

        <!-- Puzzle / Disable Card -->
        <LinearLayout
            android:id="@+id/puzzleCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="16dp"
            android:layout_marginBottom="8dp">

            <!-- Status row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/alerts_label"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/white" />

                <TextView
                    android:id="@+id/statusText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/status_active"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/green" />

            </LinearLayout>

            <!-- ── PUZZLE SECTION (shown when alerts are enabled) ── -->
            <LinearLayout
                android:id="@+id/puzzleSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/solve_to_disable"
                    android:textSize="11sp"
                    android:textColor="@color/white"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:id="@+id/puzzleEquationText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="sqrt(? × ? + ?) = ?"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:layout_marginBottom="10dp" />

                <EditText
                    android:id="@+id/puzzleAnswerInput"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:hint="@string/puzzle_hint"
                    android:inputType="numberDecimal"
                    android:textSize="14sp"
                    android:textColor="@color/white"
                    android:textColorHint="@color/subtitle"
                    android:background="@null"
                    android:paddingBottom="4dp"
                    android:layout_marginBottom="2dp" />

                <!-- Thin divider under input -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/puzzleErrorText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/error_incorrect"
                    android:textSize="12sp"
                    android:textColor="@color/red"
                    android:visibility="gone"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/disableAlertsBtn"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="@string/btn_disable_alerts"
                    android:backgroundTint="@color/green"
                    android:textColor="@color/black"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- ── RESUME SECTION (shown when alerts are disabled) ── -->
            <LinearLayout
                android:id="@+id/resumeSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/alerts_off_message"
                    android:textSize="12sp"
                    android:textColor="@color/white"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/resumeTimeText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="11sp"
                    android:textStyle="italic"
                    android:textColor="@color/white"
                    android:layout_marginBottom="12dp" />

                <Button
                    android:id="@+id/resumeAlertsBtn"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="@string/btn_resume_alerts"
                    android:backgroundTint="@color/green"
                    android:textColor="@color/black"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

        <!-- Permissions Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="16dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/permissions_label"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/dndStatusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Checking..."
                android:textSize="12sp"
                android:textColor="@color/white"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/dndPermissionBtn"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="@string/btn_dnd"
                    android:backgroundTint="@color/accent"
                    android:textColor="@color/black"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="4dp" />

                <Button
                    android:id="@+id/alarmPermissionBtn"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="@string/btn_alarm"
                    android:backgroundTint="@color/divider"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginStart="4dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Alert Schedule Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="16dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/schedule_label"
                android:textSize="11sp"
                android:textColor="@color/white"
                android:letterSpacing="0.15"
                android:layout_marginBottom="8dp" />

            <!-- 20% row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/battery_20"
                    android:textSize="14sp"
                    android:textColor="@color/white" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/siren_30s"
                    android:textSize="13sp"
                    android:textColor="@color/white"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Divider -->
            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/divider" android:layout_marginBottom="8dp"/>

            <!-- 15% row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/battery_15"
                    android:textSize="14sp"
                    android:textColor="@color/white" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/siren_1m"
                    android:textSize="13sp"
                    android:textColor="@color/white"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Divider -->
            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/divider" android:layout_marginBottom="8dp"/>

            <!-- 10% row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/battery_10"
                    android:textSize="14sp"
                    android:textColor="@color/white" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/siren_1m"
                    android:textSize="13sp"
                    android:textColor="@color/white"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>

        <!-- Note -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/info_note"
            android:textSize="10sp"
            android:textColor="@color/white"
            android:layout_marginBottom="16dp" />

    </LinearLayout>
</ScrollView>
